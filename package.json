    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.4",
    "dotenv": "^16.4.7",
    "jsdom": "^25.0.1",
    "netlify-cli": "^26.0.2",
    "start-server-and-test": "^3.0.5",
    "testcafe": "^3.7.4",
    "vite": "^5.4.11",
