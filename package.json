{
  "name": "cashflow-tracker",
  "private": true,
  "version": "5.0.0",
  "type": "module",
  "description": "Personal finance tracker with hybrid local + Claude AI transaction parser. Quiet Wealth edition.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
