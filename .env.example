# Anthropic API key for the AI Parse feature.
# Get one at https://console.anthropic.com
# This key is read by the Vite dev-server proxy ONLY — it never reaches the browser bundle.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: override the model. Default is claude-haiku-4-5-20251001.
# Other options: claude-sonnet-4-6, claude-opus-4-7
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
